# Ce fichier est utilisé par docker-compose.yml (déploiement Docker).
# Copiez-le en ".env" à la racine du projet (même dossier que docker-compose.yml)
# et renseignez des valeurs fortes avant tout déploiement réel.
#
# Note : ceci est différent de backend/.env, qui n'est utilisé que lorsque
# le serveur tourne directement avec `npm start` (sans Docker).

PGPASSWORD=changez-moi-mot-de-passe-fort
JWT_SECRET=changez-moi-chaine-aleatoire-longue

# Adresse exacte du site une fois le sous-domaine confirmé
# (ex: https://contraventions.dgecmr.ne). Laisser vide en développement local.
CORS_ORIGIN=
