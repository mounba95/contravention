# Copiez ce fichier en ".env" et ajustez les valeurs si besoin.

# Base de données PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=contraventions_dev
PGDATABASE=contraventions_db

# Sécurité
JWT_SECRET=changez-moi-en-production

# CORS — à définir en production avec l'adresse exacte du site
# (ex: https://contraventions.dgecmr.ne). Laisser vide en développement.
CORS_ORIGIN=

# URL publique du site — sert à construire les liens de paiement envoyés par
# SMS (ex: https://contraventions.dgecmr.ne). En développement, laisser vide :
# le lien pointera automatiquement vers http://localhost:PORT.
PUBLIC_URL=

# Environnement
NODE_ENV=development

# Serveur
PORT=3000
